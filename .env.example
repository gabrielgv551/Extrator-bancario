# Configurações legadas do Pluggy (mantidas enquanto houver itens históricos)
PLUGGY_CLIENT_ID=seu_client_id_aqui
PLUGGY_CLIENT_SECRET=seu_client_secret_aqui
# Obrigatório em produção para receber webhooks de itens e transações da Pluggy.
PLUGGY_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/pluggy
# Recomendado: segredo para validar webhooks da Pluggy.
PLUGGY_WEBHOOK_SECRET=uma_senha_secreta_aleatoria

# Configurações do novo provedor Klavi (Open Finance PJ)
# Base da API: use https://api-sandbox.klavi.ai/data/v1 para testes.
KLAVI_API_BASE=https://api.klavi.ai/data/v1
KLAVI_ACCESS_KEY=sua_access_key_klavi
KLAVI_SECRET_KEY=seu_secret_key_klavi
# Obrigatório em produção: URL pública HTTPS para webhooks de relatório/consent.
KLAVI_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/klavi
# Segredo para validar webhooks da Klavi (header Authorization: Bearer …).
KLAVI_WEBHOOK_SECRET=uma_senha_secreta_aleatoria

DATABASE_URL=postgresql://postgres:sua_senha@37.60.236.200:5432/extratos
CRON_SECRET=uma_senha_secreta_aleatoria
ADMIN_PASSWORD=sua_senha_admin
